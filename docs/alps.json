{
  "$schema": "https://alps-io.github.io/schemas/alps.json",
  "alps": {
    "title": "Constraint Engine API",
    "doc": {"value": "AI×人間の協働における判断プロセスの記録・可視化プラットフォーム"},
    "descriptor": [
      {"id": "checkpointId", "title": "Checkpoint ID", "def": "https://schema.org/identifier"},
      {"id": "sessionId", "title": "AI対話セッション識別子", "def": "https://schema.org/identifier"},
      {"id": "taskContext", "title": "業務タスクの説明", "def": "https://schema.org/description"},
      {"id": "aiProposal", "title": "AIが提案した内容", "def": "https://schema.org/text"},
      {"id": "humanFinal", "title": "人間が最終的に出した内容", "def": "https://schema.org/text"},
      {"id": "diff", "title": "提案と最終の差分", "def": "https://schema.org/text"},
      {"id": "tag", "title": "分類タグ (factual|strategic|stylistic)", "def": "https://schema.org/category"},
      {"id": "confidence", "title": "タグの確信度 (estimated|stated)", "def": "https://schema.org/category"},
      {"id": "dateCreated", "title": "作成日時", "def": "https://schema.org/dateCreated"},
      {"id": "totalCheckpoints", "title": "合計Checkpoint数", "def": "https://schema.org/Integer"},
      {"id": "factualCount", "title": "Factual分類の件数", "def": "https://schema.org/Integer"},
      {"id": "strategicCount", "title": "Strategic分類の件数", "def": "https://schema.org/Integer"},
      {"id": "stylisticCount", "title": "Stylistic分類の件数", "def": "https://schema.org/Integer"},
      {"id": "periodStart", "title": "集計期間の開始日", "def": "https://schema.org/Date"},
      {"id": "periodEnd", "title": "集計期間の終了日", "def": "https://schema.org/Date"},
      {
        "id": "CheckpointList",
        "title": "Checkpoint一覧",
        "descriptor": [
          {"href": "#checkpointId"},
          {"href": "#sessionId"},
          {"href": "#taskContext"},
          {"href": "#tag"},
          {"href": "#confidence"},
          {"href": "#dateCreated"},
          {"href": "#goCheckpoint"},
          {"href": "#goPatternDashboard"},
          {"href": "#doRecordCheckpoint"}
        ]
      },
      {
        "id": "Checkpoint",
        "title": "Checkpoint詳細",
        "descriptor": [
          {"href": "#checkpointId"},
          {"href": "#sessionId"},
          {"href": "#taskContext"},
          {"href": "#aiProposal"},
          {"href": "#humanFinal"},
          {"href": "#diff"},
          {"href": "#tag"},
          {"href": "#confidence"},
          {"href": "#dateCreated"},
          {"href": "#goCheckpointList"}
        ]
      },
      {
        "id": "PatternDashboard",
        "title": "判断パターンダッシュボード",
        "descriptor": [
          {"href": "#totalCheckpoints"},
          {"href": "#factualCount"},
          {"href": "#strategicCount"},
          {"href": "#stylisticCount"},
          {"href": "#periodStart"},
          {"href": "#periodEnd"},
          {"href": "#goCheckpointList"}
        ]
      },
      {
        "id": "goCheckpointList",
        "type": "safe",
        "rt": "#CheckpointList",
        "title": "Checkpoint一覧を表示",
        "descriptor": [
          {"href": "#tag"},
          {"href": "#sessionId"}
        ]
      },
      {
        "id": "goCheckpoint",
        "type": "safe",
        "rt": "#Checkpoint",
        "title": "Checkpoint詳細を表示",
        "descriptor": [
          {"href": "#checkpointId"}
        ]
      },
      {
        "id": "doRecordCheckpoint",
        "type": "unsafe",
        "rt": "#Checkpoint",
        "title": "Checkpointを記録",
        "descriptor": [
          {"href": "#sessionId"},
          {"href": "#taskContext"},
          {"href": "#aiProposal"},
          {"href": "#humanFinal"},
          {"href": "#diff"},
          {"href": "#tag"},
          {"href": "#confidence"}
        ]
      },
      {
        "id": "goPatternDashboard",
        "type": "safe",
        "rt": "#PatternDashboard",
        "title": "判断パターンダッシュボードを表示",
        "descriptor": [
          {"href": "#periodStart"},
          {"href": "#periodEnd"}
        ]
      }
    ]
  }
}
