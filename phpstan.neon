parameters:
  level: 6
  paths:
    - src
    - tests
  excludePaths:
    - tests/Http/index.php
  ignoreErrors:
    # PHPUnit with() named arguments: PHPUnit annotates @no-named-arguments but tests use snake_case named args for readability
    -
      identifier: argument.named
      path: tests/
    # BEAR.Sunday test pattern: assert($ro instanceof ResourceObject) is idiomatic
    -
      identifier: instanceof.alwaysTrue
      path: tests/
    -
      identifier: function.alreadyNarrowedType
      path: tests/
